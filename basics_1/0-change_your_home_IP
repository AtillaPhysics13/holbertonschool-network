#!/usr/bin/env bash
# This script configures local host resolution rules in /etc/hosts

# 1. Update localhost to resolve to 127.0.0.2
# If localhost already exists in the file, we update its IP. Otherwise, we append it.
if grep -q "localhost" /etc/hosts; then
    sed -i 's/\([0-9]\{1,3\}\.\)\{3\}[0-9]\{1,3\}\s*localhost/127.0.0.2 localhost/g' /etc/hosts
else
    echo "127.0.0.2 localhost" >> /etc/hosts
fi

# 2. Update facebook.com to resolve to 8.8.8.8
# If facebook.com already exists, we update it. Otherwise, we append it.
if grep -q "facebook.com" /etc/hosts; then
    sed -i 's/\([0-9]\{1,3\}\.\)\{3\}[0-9]\{1,3\}\s*facebook.com/8.8.8.8 facebook.com/g' /etc/hosts
else
    echo "8.8.8.8 facebook.com" >> /etc/hosts
fi
