#!/usr/bin/env bash
set -e

HOSTS_FILE="/etc/hosts"
TMP_FILE="$(mktemp)"

# Keep all lines except ones defining localhost/facebook.com/www.facebook.com
awk '
{
  is_localhost=0; is_fb=0;
  for (i=2; i<=NF; i++) {
    if ($i=="localhost") is_localhost=1;
    if ($i=="facebook.com" || $i=="www.facebook.com") is_fb=1;
  }
  if (!is_localhost && !is_fb) print $0;
}
' "$HOSTS_FILE" > "$TMP_FILE"

# Add required mappings
{
  echo "127.0.0.2 localhost"
  echo "8.8.8.8 facebook.com"
} >> "$TMP_FILE"

# Overwrite without rename issues
cat "$TMP_FILE" > "$HOSTS_FILE"
rm -f "$TMP_FILE"
