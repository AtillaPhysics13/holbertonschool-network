#!/usr/bin/env bash
# This script configures local host resolution rules in /etc/hosts safely

# Read the current content of /etc/hosts
content=$(cat /etc/hosts)

# Modify localhost configuration
if echo "$content" | grep -q "localhost"; then
    content=$(echo "$content" | sed 's/127\.0\.0\.1\s*localhost/127.0.0.2 localhost/g')
else
    content="$content"$'\n'"127.0.0.2 localhost"
fi

# Modify facebook.com configuration
if echo "$content" | grep -q "facebook.com"; then
    content=$(echo "$content" | sed 's/[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}\s*facebook.com/8.8.8.8 facebook.com/g')
else
    content="$content"$'\n'"8.8.8.8 facebook.com"
fi

# Overwrite /etc/hosts safely using standard redirection
echo "$content" > /etc/hosts
