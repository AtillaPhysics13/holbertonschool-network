#!/usr/bin/env bash
# Changes localhost to 127.0.0.2 and facebook.com to 8.8.8.8 in /etc/hosts
set -e

HOSTS_FILE="/etc/hosts"
TMP_FILE="$(mktemp)"

awk '
{
  is_localhost=0; is_fb=0;
  for (i=2; i<=NF; i++) {
    if ($i=="localhost") is_localhost=1;
    if ($i=="facebook.com" || $i=="www.facebook.com") is_fb=1;
  }
  if (!is_localhost && !is_fb) print $0;
}
' "$HOSTS_FILE" > "$TMP_FILE"

echo "127.0.0.2 localhost" >> "$TMP_FILE"
echo "8.8.8.8 facebook.com" >> "$TMP_FILE"

cat "$TMP_FILE" > "$HOSTS_FILE"
rm -f "$TMP_FILE"
